# ─── LLM Configuration ───────────────────────────────────────────────────────
# Option 1: Google Gemini Free Tier (recommended for quick setup)
#   Get a free key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_free_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Option 2: Ollama (fully local, no API key needed)
#   Install: https://ollama.com
#   Then run: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── Notes ───────────────────────────────────────────────────────────────────
# If GEMINI_API_KEY is set, the system uses Gemini.
# If GEMINI_API_KEY is empty/unset, the system falls back to Ollama.
